---

---
<section id="sedes" class="w-full max-w-7xl mx-auto px-6 py-20">

  <!-- Header -->
  <div class="max-w-3xl mb-12">
    <span class="text-text-feature font-semibold uppercase tracking-wider">
      Nuestras Sedes
    </span>

    <h2 class="text-4xl md:text-5xl font-bold text-black mt-3 mb-5">
      Encuentra la sede más cercana para ti
    </h2>

    <p class="text-lg text-gray-800 leading-relaxed">
      Contamos con diversas sedes diseñadas para brindar una educación
      integral en espacios seguros, modernos y adecuados para el aprendizaje.
    </p>
  </div>

  <!-- Grid sedes -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

    <!-- SEDE 1 -->
    <article class="group bg-primary rounded-4xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 border border-secondary/10">

      <div class="overflow-hidden">
        <img
          src="/jicamarca1.png"
          alt="Sede 1"
          class="w-full h-72 object-cover group-hover:scale-105 transition-transform duration-700"
        >
      </div>

      <div class="p-7">
        <span class="text-secondary text-sm font-medium">
          Sede
        </span>

        <h3 class="text-2xl font-bold text-text mt-2">
          Jicamarca
        </h3>

        <p class="text-text-secondary mt-3 leading-relaxed">
          Av. Sinchi Roca, Mz j7, lt8, El Pedregal (Altura del Paradero La Torre)
        </p>

        <button class="mt-6 text-secondary font-medium hover:translate-x-1 transition-transform duration-300">
          Ver ubicación →
        </button>
      </div>

    </article>

    <!-- SEDE 2 -->
    <article class="group bg-primary rounded-4xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 border border-secondary/10">

      <div class="overflow-hidden">
        <img
          src="/central1.png"
          alt="Sede 2"
          class="w-full h-72 object-cover group-hover:scale-105 transition-transform duration-700"
        >
      </div>

      <div class="p-7">
        <span class="text-secondary text-sm font-medium">
          Sede
        </span>

        <h3 class="text-2xl font-bold text-text mt-2">
          Central
        </h3>

        <p class="text-text-secondary mt-3 leading-relaxed">
          Av. Central 4771 | Mz. G Lt. 26
        </p>

        <button class="mt-6 text-secondary font-medium hover:translate-x-1 transition-transform duration-300">
          Ver ubicación →
        </button>
      </div>

    </article>

    <!-- SEDE 3 -->
    <article class="group bg-primary rounded-4xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 border border-secondary/10">

      <div class="overflow-hidden">
        <img
          src="/wise2.png"
          alt="Sede 3"
          class="w-full h-72 object-cover group-hover:scale-105 transition-transform duration-700"
        >
      </div>

      <div class="p-7">
        <span class="text-secondary text-sm font-medium">
          Sede
        </span>

        <h3 class="text-2xl font-bold text-text mt-2">
          Wisse
        </h3>

        <p class="text-text-secondary mt-3 leading-relaxed">
          Av. Proceres de la Independencia Mz. F11 Lt. 40-41-42
        </p>

        <button class="mt-6 text-secondary font-medium hover:translate-x-1 transition-transform duration-300">
          Ver ubicación →
        </button>
      </div>

    </article>

    <!-- SEDE 4 -->
    <article class="group bg-primary rounded-4xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 border border-secondary/10">

      <div class="overflow-hidden">
        <img
          src="/wise1.png"
          alt="Sede 4"
          class="w-full h-72 object-cover group-hover:scale-105 transition-transform duration-700"
        >
      </div>

      <div class="p-7">
        <span class="text-secondary text-sm font-medium">
          Sede
        </span>

        <h3 class="text-2xl font-bold text-text mt-2">
          Wisse
        </h3>

        <p class="text-text-secondary mt-3 leading-relaxed">
          Av. Proceres de la Independencia Mz. F11 Lt. 40-41-42
        </p>

        <button class="mt-6 text-secondary font-medium hover:translate-x-1 transition-transform duration-300">
          Ver ubicación →
        </button>
      </div>

    </article>

  </div>

</section>
