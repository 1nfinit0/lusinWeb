<header class="sticky top-0 z-999 flex items-center justify-between bg-primary backdrop-blur-sm border-b border-secondary p-4 md:px-25">

  <div class="flex items-center gap-2">
    <img class="w-18 md:w-22" src="/icon_no_background.png" alt="Logo">
  </div>

  <!-- Desktop -->
  <nav class="hidden sm:block">
    <ul class="flex items-center gap-4">
      <li><a href="#" class="text-text hover:text-text-feature">Quienes Somos</a></li>
      <li><a href="#" class="text-text hover:text-text-feature">Nuestras Sedes</a></li>
      <li><a href="#" class="text-text hover:text-text-feature">Contactos</a></li>
    </ul>
  </nav>

  <!-- Botón -->
  <button
    id="menu-button"
    class="sm:hidden"
    aria-label="Menu"
  >
    <svg
      class="w-7 h-7 text-white"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M4 6h16M4 12h16M4 18h16"
      ></path>
    </svg>
  </button>

  <!-- Menú móvil -->
  <nav
    id="mobile-menu"
    class="sm:hidden absolute top-full left-0 w-full overflow-hidden
           max-h-0 opacity-0 -translate-y-4
           transition-all duration-300 ease-in-out
           bg-primary border-b border-gray-200"
  >
    <hr class="border-secondary">

    <ul class="flex flex-col p-4 gap-3 justify-center">
      <li>
        <a href="#" class="text-text hover:text-text-feature">
          Quienes Somos
        </a>
      </li>

      <hr class="border-secondary/50">

      <li>
        <a href="#" class="text-text hover:text-text-feature">
          Nuestras Sedes
        </a>
      </li>

      <hr class="border-secondary/50">

      <li>
        <a href="#" class="text-text hover:text-text-feature">
          Contactos
        </a>
      </li>
    </ul>
  </nav>

</header>

<script>
  const menuButton = document.getElementById("menu-button");
  const mobileMenu = document.getElementById("mobile-menu");

  if (menuButton && mobileMenu) {
    menuButton.addEventListener("click", () => {

      mobileMenu.classList.toggle("max-h-0");
      mobileMenu.classList.toggle("max-h-80");

      mobileMenu.classList.toggle("opacity-0");
      mobileMenu.classList.toggle("opacity-100");

      mobileMenu.classList.toggle("-translate-y-4");
      mobileMenu.classList.toggle("translate-y-0");

    });
  }
</script>